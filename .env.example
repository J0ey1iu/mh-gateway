# Provider environment variables for mh-gateway.
# Copy this file to .env and fill in your credentials.
#
# Usage:
#   cp .env.example .env
#   Then edit .env with your actual keys.
#
# These are read by dev-win.ps1 and dev.sh automatically.

# API key for the OpenAI-compatible LLM provider.
MH_API_KEY=

# Base URL for the OpenAI-compatible LLM provider.
MH_BASE_URL=https://aihubmix.com/v1
